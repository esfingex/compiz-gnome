<?xml version="1.0" encoding="UTF-8"?>
<schemalist>
  <schema id="org.gnome.shell.extensions.compiz-gnome" path="/org/gnome/shell/extensions/compiz-gnome/">

    <!-- ===== EFECTOS ON/OFF ===== -->
    <key name="water-enabled" type="b">
      <default>false</default>
      <summary>Activar efecto Water Ripple</summary>
      <description>Simula ondas de agua físicas al arrastrar ventanas</description>
    </key>

    <key name="wobbly-enabled" type="b">
      <default>false</default>
      <summary>Activar efecto Wobbly Windows</summary>
      <description>Ventanas gelatinosas con física de resortes y Bézier bicúbica</description>
    </key>

    <key name="burn-enabled" type="b">
      <default>false</default>
      <summary>Activar efecto Burn Firepaint</summary>
      <description>Quema la ventana con partículas de fuego en Compute Shader</description>
    </key>

    <key name="shift-enabled" type="b">
      <default>false</default>
      <summary>Activar Shift Cover Flow</summary>
      <description>Navegación de ventanas con reflexión planar y desenfoque glossy</description>
    </key>

    <key name="ring-enabled" type="b">
      <default>false</default>
      <summary>Activar Ring Switcher</summary>
      <description>Carrusel 3D inclinado para Alt+Tab</description>
    </key>

    <key name="animation-enabled" type="b">
      <default>false</default>
      <summary>Activar Animation Suite</summary>
      <description>Magic Lamp, Curl, Explode al abrir/cerrar ventanas</description>
    </key>

    <key name="blur-enabled" type="b">
      <default>false</default>
      <summary>Activar Dual Kawase Blur</summary>
      <description>Desenfoque de fondo multitap con computación GPU</description>
    </key>

    <!-- ===== ANNOTATE & PAINTFIRE ===== -->
    <key name="annotate-enabled" type="b">
      <default>false</default>
      <summary>Habilitar Annotate &amp; Paintfire</summary>
    </key>

    <key name="annotate-mode" type="s">
      <default>'ink'</default>
      <summary>Modo de dibujo: fire, ink, highlight, eraser</summary>
    </key>

    <key name="annotate-brush-size" type="i">
      <default>10</default>
      <range min="1" max="100"/>
      <summary>Tamaño del pincel</summary>
    </key>

    <!-- ===== SHOWMOUSE ===== -->
    <key name="showmouse-enabled" type="b">
      <default>false</default>
      <summary>Habilitar Showmouse</summary>
    </key>

    <key name="showmouse-effect" type="s">
      <default>'ring'</default>
      <summary>Efecto de cursor: ring, sparkle, trail, ripple</summary>
    </key>

    <key name="showmouse-ring-radius" type="i">
      <default>50</default>
      <range min="10" max="200"/>
      <summary>Radio del anillo</summary>
    </key>

    <key name="showmouse-num-particles" type="i">
      <default>512</default>
      <range min="64" max="2048"/>
      <summary>Cantidad de partículas</summary>
    </key>

    <!-- ===== MAGNIFIER ===== -->
    <key name="magnifier-enabled" type="b">
      <default>false</default>
      <summary>Habilitar Magnifier</summary>
    </key>

    <key name="magnifier-zoom" type="d">
      <default>2.0</default>
      <range min="1.0" max="10.0"/>
      <summary>Factor de zoom</summary>
    </key>

    <key name="magnifier-radius" type="i">
      <default>150</default>
      <range min="50" max="500"/>
      <summary>Radio de la lupa</summary>
    </key>

    <!-- ===== GROUP ===== -->
    <key name="group-enabled" type="b">
      <default>false</default>
      <summary>Habilitar Group (agrupación de ventanas)</summary>
    </key>


    <key name="group-shortcut" type="s">
      <default>'&lt;Super&gt;g'</default>
      <summary>Atajo para agrupar ventanas</summary>
    </key>

    <!-- ===== PARÁMETROS DE FÍSICA ===== -->
    <key name="water-speed" type="d">
      <default>0.5</default>
      <range min="0.1" max="2.0"/>
      <summary>Velocidad de propagación de ondas de agua</summary>
    </key>

    <key name="wobbly-spring-k" type="d">
      <default>2.0</default>
      <range min="0.5" max="10.0"/>
      <summary>Constante de rigidez de resortes para Wobbly (Tensión)</summary>
    </key>

    <key name="wobbly-friction" type="d">
      <default>0.82</default>
      <range min="0.5" max="0.99"/>
      <summary>Amortiguamiento de fricción para Wobbly</summary>
    </key>

    <key name="wobbly-max-deformation" type="d">
      <default>60.0</default>
      <range min="10.0" max="200.0"/>
      <summary>Deformación física máxima de Wobbly (px)</summary>
    </key>

    <key name="wobbly-impulse" type="d">
      <default>0.60</default>
      <range min="0.1" max="3.0"/>
      <summary>Sensibilidad del impulso por movimiento del ratón</summary>
    </key>


    <key name="burn-particles" type="i">
      <default>50000</default>
      <range min="1000" max="100000"/>
      <summary>Cantidad de partículas de fuego</summary>
    </key>

    <key name="blur-radius" type="i">
      <default>15</default>
      <range min="1" max="50"/>
      <summary>Radio de desenfoque en píxeles</summary>
    </key>

    <!-- ===== ATAJOS DE TECLADO ===== -->
    <key name="ring-shortcut" type="s">
      <default>'&lt;Super&gt;w'</default>
      <summary>Atajo para abrir Ring Switcher</summary>
    </key>

    <key name="shift-shortcut" type="s">
      <default>'&lt;Super&gt;e'</default>
      <summary>Atajo para abrir Shift Cover Flow</summary>
    </key>

    <key name="expo-shortcut" type="s">
      <default>'&lt;Super&gt;s'</default>
      <summary>Atajo para abrir Expo/Scale</summary>
    </key>

    <!-- ===== CONFIGURACIÓN AVANZADA ===== -->
    <key name="socket-path" type="s">
      <default>''</default>
      <summary>Ruta del Unix Domain Socket IPC</summary>
      <description>Ruta al socket IPC (por defecto $XDG_RUNTIME_DIR/compiz_gnome_engine.sock o /tmp/compiz_gnome_engine.sock)</description>
    </key>

    <key name="fixed-timestep-hz" type="i">
      <default>120</default>
      <range min="30" max="240"/>
      <summary>Frecuencia fija de simulación física (Hz)</summary>
    </key>


  </schema>
</schemalist>
